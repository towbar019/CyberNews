---
import type { HTMLAttributes } from "astro/types";
import { getLang } from "../lib/i18n";

interface Props extends HTMLAttributes<"div"> {
  title?: string;
  description?: string;
}

const { title = "SecurityNews", description = "Veille cybersécurité personnalisée par profils" } = Astro.props;
const lang = getLang(Astro.url);
const currentPath = Astro.url.pathname;

// Build lang switch URLs (keep current path, just toggle lang param)
const frUrl = currentPath + "?lang=fr";
const enUrl = currentPath + "?lang=en";

const navLinks = [
  { href: "/", labelFr: "Home",          labelEn: "Home" },
  { href: "/security-news", labelFr: "SecurityNews", labelEn: "SecurityNews" },
  { href: "/profiles",  labelFr: "Profils",      labelEn: "Profiles" },
  { href: "/reporting", labelFr: "Reporting",    labelEn: "Reporting" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

function navHref(href: string): string {
  return lang === "en" ? `${href}?lang=en` : href;
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | SecurityNews — CNEMEA</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/nemea-logo.png" type="image/png" />
  <style>
    :root {
      --bg:       #080d1a;
      --bg2:      #0d1424;
      --bg3:      #111827;
      --bg4:      #1a2235;
      --border:   #1e2d47;
      --border2:  #2a3f60;
      --text:     #e8edf5;
      --text-muted: #8899b4;
      --accent:   #3b82f6;
      --accent-bright: #60a5fa;
      --accent-glow:   #3b82f640;
      --cyan:     #22d3ee;
      --red:      #ef4444;
      --orange:   #f59e0b;
      --green:    #22c55e;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Inter', sans-serif;
      font-size: 15px;
    }
    body { min-height: 100vh; display: flex; flex-direction: column; background: var(--bg); }
    a { color: var(--accent-bright); text-decoration: none; }
    a:hover { color: var(--cyan); }
    code { font-family: 'JetBrains Mono', monospace; background: var(--bg4); padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }

    /* Navbar */
    .navbar {
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      height: 58px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      flex-shrink: 0;
    }
    .navbar-logo { width: 36px; height: 36px; object-fit: contain; }
    .navbar-brand-text { font-size: 1.05rem; font-weight: 700; color: var(--text); letter-spacing: 0.04em; }
    .navbar-nav { display: flex; align-items: center; gap: 0.15rem; flex: 1; }
    .nav-link {
      padding: 0.35rem 0.85rem;
      border-radius: 6px;
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-muted);
      transition: color .15s, background .15s;
    }
    .nav-link:hover { color: var(--text); background: var(--bg4); }
    .nav-link.active { color: var(--accent-bright); background: var(--accent-glow); }
    .navbar-lang { margin-left: auto; display: flex; align-items: center; gap: 0.4rem; }
    .lang-btn {
      padding: 3px 10px;
      border-radius: 5px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--text-muted);
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition: border-color .15s, color .15s;
    }
    .lang-btn:hover { border-color: var(--accent); color: var(--accent-bright); }
    .lang-btn.active { border-color: var(--accent); color: var(--accent-bright); background: var(--accent-glow); }

    main { flex: 1; }

    .footer {
      border-top: 1px solid var(--border);
      padding: 1.25rem 2rem;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.78rem;
      background: var(--bg2);
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href={navHref("/")} class="navbar-brand">
      <img src="/nemea-logo.png" alt="CNEMEA" class="navbar-logo" />
      <span class="navbar-brand-text">CNEMEA</span>
    </a>

    <div class="navbar-nav">
      {navLinks.map(link => (
        <a
          href={navHref(link.href)}
          class={`nav-link${isActive(link.href) ? " active" : ""}`}
        >
          {lang === "en" ? link.labelEn : link.labelFr}
        </a>
      ))}
    </div>

    <div class="navbar-lang">
      <a href={frUrl} class={`lang-btn${lang === "fr" ? " active" : ""}`}>FR</a>
      <a href={enUrl} class={`lang-btn${lang === "en" ? " active" : ""}`}>EN</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    © {new Date().getFullYear()} CNEMEA — SecurityNews
  </footer>
</body>
</html>
